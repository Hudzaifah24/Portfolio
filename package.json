{
  "devDependencies": {
    "husky": "^8.0.1",
    "postcss": "^8.4.16",
    "postcss-cli": "^10.0.0",
    "tailwindcss": "^3.1.8"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run tailwindcss -i ./styles/input.css -o ./dist/output.css --watch"
    }
  },
  "scripts": {
    "start": "tailwindcss -i ./styles/input.css -o ./dist/output.css --watch"
  }
}
